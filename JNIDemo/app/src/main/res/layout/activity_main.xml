<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/jni_dashboard_title"
            android:textColor="#1A237E"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/jni_dashboard_subtitle"
            android:textColor="#5C6BC0"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_section_1"
                android:textColor="#37474F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <Button
                android:id="@+id/btnTriggerHello"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_label_hello"
                android:backgroundTint="#2E7D32"/>
            <TextView
                android:id="@+id/tvHelloResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/jni_waiting"
                android:textColor="#2E7D32"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_section_2"
                android:textColor="#37474F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etFactorielInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Exemple: 12"
                android:inputType="numberSigned"
                android:layout_marginBottom="8dp"/>
            <Button
                android:id="@+id/btnCalculerFact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_label_calc"
                android:backgroundTint="#1A237E"/>
            <TextView
                android:id="@+id/tvFactResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/jni_waiting"
                android:textColor="#1A237E"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_section_3"
                android:textColor="#37474F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etStringInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Texte à traiter..."
                android:inputType="text"
                android:layout_marginBottom="8dp"/>
            <Button
                android:id="@+id/btnInverserString"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_label_reverse"
                android:backgroundTint="#1A237E"/>
            <TextView
                android:id="@+id/tvReverseResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/jni_waiting"
                android:textColor="#1A237E"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_section_4"
                android:textColor="#37474F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etArrayInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombres séparés par des virgules (ex: 5,15,45)"
                android:inputType="text"
                android:layout_marginBottom="8dp"/>
            <Button
                android:id="@+id/btnCalculerSomme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_label_array"
                android:backgroundTint="#1A237E"/>
            <TextView
                android:id="@+id/tvArrayResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/jni_waiting"
                android:textColor="#1A237E"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_section_5"
                android:textColor="#FF6D00"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <Button
                android:id="@+id/btnRunBenchmark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_label_benchmark"
                android:backgroundTint="#FF6D00"/>
            <TextView
                android:id="@+id/tvBenchmarkResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/jni_waiting"
                android:textColor="#212121"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/footer_note"
            android:textColor="#78909C"
            android:textSize="11sp"
            android:textAlignment="center" />

    </LinearLayout>
</ScrollView>